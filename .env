GEMINI_API_KEY=

# Firebase configuration (paste the JSON object from your Firebase project settings)
NEXT_PUBLIC_FIREBASE_CONFIG='{"apiKey":"AIza...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}'

# A unique ID for your app instance to separate data in Firestore
NEXT_PUBLIC_APP_ID="varsity-group-pro"

# NextAuth / Azure AD
AUTH_SECRET="replace-with-a-long-random-secret"
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# Allowed email domains (comma-separated). Use this if staff and students live on different domains.
AFDA_ALLOWED_EMAIL_DOMAINS="staff.afda.co.za,students.afda.co.za"