{
  "name": "afda-booking-platform",
  "version": "0.1.0",
  "description": "AFDA Booking Platform - Complete booking system for AFDA students and staff",
  "private": true,
  "workspaces": [
    "app",
    "apps/slot-booking",
    "apps/student-public",
    "apps/venue-booking",
    "apps/group-sync",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace @afda/app run dev\" \"npm --workspace @afda/backend run dev\"",
    "dev:app": "npm --workspace @afda/app run dev",
    "dev:slot-booking": "npm --workspace @afda/slot-booking run dev",
    "dev:student-public": "npm --workspace @afda/student-public run dev",
    "dev:venue-booking": "npm --workspace @afda/venue-booking run dev",
    "dev:group-sync": "npm --workspace @afda/group-sync run dev",
    "dev:server": "npm --workspace @afda/backend run dev",
    "build": "npm run build:server && npm run build:app && npm run build:slot-booking && npm run build:student-public && npm run build:venue-booking && npm run build:group-sync",
    "build:app": "npm --workspace @afda/app run build",
    "build:slot-booking": "npm --workspace @afda/slot-booking run build",
    "build:student-public": "npm --workspace @afda/student-public run build",
    "build:venue-booking": "npm --workspace @afda/venue-booking run build",
    "build:group-sync": "npm --workspace @afda/group-sync run build",
    "build:server": "npm --workspace @afda/backend run build",
    "start": "npm --workspace @afda/app run start",
    "lint": "npm run lint:server && npm run lint:app && npm run lint:slot-booking && npm run lint:student-public && npm run lint:venue-booking && npm run lint:group-sync",
    "lint:app": "npm --workspace @afda/app run lint",
    "lint:slot-booking": "npm --workspace @afda/slot-booking run lint",
    "lint:student-public": "npm --workspace @afda/student-public run lint",
    "lint:venue-booking": "npm --workspace @afda/venue-booking run lint",
    "lint:group-sync": "npm --workspace @afda/group-sync run lint",
    "lint:server": "npm --workspace @afda/backend run lint",
    "type-check": "npm run type-check:server && npm run type-check:app && npm run type-check:slot-booking && npm run type-check:student-public && npm run type-check:venue-booking && npm run type-check:group-sync",
    "type-check:app": "npm --workspace @afda/app run type-check",
    "type-check:slot-booking": "npm --workspace @afda/slot-booking run type-check",
    "type-check:student-public": "npm --workspace @afda/student-public run type-check",
    "type-check:venue-booking": "npm --workspace @afda/venue-booking run type-check",
    "type-check:group-sync": "npm --workspace @afda/group-sync run type-check",
    "type-check:server": "npm --workspace @afda/backend run build",
    "perf:test": "node tests/perf/load-test.mjs",
    "smoke:test": "./scripts/smoke-test.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "typescript": "^5.2.0",
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
